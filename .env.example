AGENTMESH_ENVIRONMENT=development
AGENTMESH_DATABASE_URL=postgresql+psycopg://agentmesh:agentmesh@127.0.0.1:5432/agentmesh
AGENTMESH_CHECKPOINT_DATABASE_URL=postgresql://agentmesh:agentmesh@127.0.0.1:5432/agentmesh
AGENTMESH_REDIS_URL=redis://127.0.0.1:6379/0
AGENTMESH_TENANT_ID=default
AGENTMESH_AGENT_ID=demo-agent
AGENTMESH_EXECUTION_STREAM=agentmesh.run-requests
AGENTMESH_DOMAIN_EVENT_STREAM=agentmesh.domain-events
AGENTMESH_EXECUTION_GROUP=agentmesh-run-workers
AGENTMESH_EXECUTION_CONSUMER_NAME=run-executor-v1
AGENTMESH_DEAD_LETTER_STREAM=agentmesh.dead-letter
AGENTMESH_WORKER_BLOCK_MS=1000
AGENTMESH_WORKER_PENDING_IDLE_MS=60000
AGENTMESH_RUN_LEASE_SECONDS=300
AGENTMESH_RELAY_BATCH_SIZE=100
AGENTMESH_RELAY_CLAIM_SECONDS=30
AGENTMESH_RELAY_RETRY_SECONDS=5
AGENTMESH_RETENTION_INTERVAL_SECONDS=300
AGENTMESH_RETENTION_BATCH_SIZE=1000
AGENTMESH_OUTBOX_RETENTION_SECONDS=604800
AGENTMESH_INBOX_RETENTION_SECONDS=2592000
AGENTMESH_REDIS_STREAM_RETENTION_SECONDS=604800
AGENTMESH_REDIS_STREAM_MAX_ENTRIES=100000
AGENTMESH_DEAD_LETTER_STREAM_RETENTION_SECONDS=2592000
AGENTMESH_DEAD_LETTER_STREAM_MAX_ENTRIES=50000
AGENTMESH_RELAY_METRICS_ENABLED=true
AGENTMESH_RELAY_METRICS_HOST=0.0.0.0
AGENTMESH_RELAY_METRICS_PORT=9464
AGENTMESH_LANGFUSE_ENABLED=false
AGENTMESH_FEATURE_PROFILE=minimal
# Optional comma-separated overrides, for example:
# AGENTMESH_FEATURE_GATES=agent_registry_management=true,artifact_service=true,mcp_read_tools=true,observability=true
AGENTMESH_FEATURE_GATES=
AGENTMESH_ARTIFACT_OWNER_ID=local-user
AGENTMESH_ARTIFACT_MAX_INLINE_BYTES=65536
AGENTMESH_MCP_WORKSPACE_ROOT=.
AGENTMESH_MCP_WORKSPACE_TIMEOUT_SECONDS=30
AGENTMESH_MCP_WORKSPACE_MAX_BYTES=65536
AGENTMESH_MCP_MAX_RESULT_BYTES=262144

# Required only when AGENTMESH_LANGFUSE_ENABLED=true. The official LANGFUSE_*
# names are accepted too. Enable the observability feature at the same time.
AGENTMESH_LANGFUSE_PUBLIC_KEY=
AGENTMESH_LANGFUSE_SECRET_KEY=
AGENTMESH_LANGFUSE_BASE_URL=http://localhost:3000
AGENTMESH_LANGFUSE_TIMEOUT_SECONDS=5
