AGENTMESH_ENVIRONMENT=development
AGENTMESH_DATABASE_URL=postgresql+psycopg://agentmesh:agentmesh@127.0.0.1:5432/agentmesh
AGENTMESH_CHECKPOINT_DATABASE_URL=postgresql://agentmesh:agentmesh@127.0.0.1:5432/agentmesh
AGENTMESH_REDIS_URL=redis://127.0.0.1:6379/0
AGENTMESH_TENANT_ID=default
AGENTMESH_AGENT_ID=demo-agent
AGENTMESH_EXECUTION_STREAM=agentmesh.run-requests
AGENTMESH_DOMAIN_EVENT_STREAM=agentmesh.domain-events
AGENTMESH_EXECUTION_GROUP=agentmesh-run-workers
AGENTMESH_EXECUTION_CONSUMER_NAME=run-executor-v1
AGENTMESH_DEAD_LETTER_STREAM=agentmesh.dead-letter
AGENTMESH_WORKER_BLOCK_MS=1000
AGENTMESH_WORKER_PENDING_IDLE_MS=60000
AGENTMESH_RUN_LEASE_SECONDS=300
AGENTMESH_RELAY_BATCH_SIZE=100
AGENTMESH_RELAY_CLAIM_SECONDS=30
AGENTMESH_RELAY_RETRY_SECONDS=5
AGENTMESH_LANGFUSE_ENABLED=false

# Required only when AGENTMESH_LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=http://localhost:3000
